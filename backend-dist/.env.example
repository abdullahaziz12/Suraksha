# Environment Configuration
# Copy this file to .env and update with your settings

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=suraksha-secret-key-2026-change-in-production
JWT_EXPIRY=7d

# Database (if migrating from in-memory)
# DB_HOST=localhost
# DB_PORT=27017
# DB_NAME=suraksha
# DB_USER=admin
# DB_PASSWORD=password

# MongoDB Atlas (recommended free persistent database)
# MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/suraksha?retryWrites=true&w=majority

# SMS Service (Twilio - required for real SOS/contact SMS delivery)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+12345678901

# Chat encryption (used for trustee chat message encryption)
# CHAT_ENCRYPTION_KEY=change-this-to-a-long-random-secret

# Email Service (for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=your-email@gmail.com

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
